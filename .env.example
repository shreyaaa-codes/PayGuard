# Example environment variables

# Monad / RPC
MONAD_RPC_URL=https://rpc.testnet.monad.example
CONTRACT_ADDRESS=

# Private key for backend actions (keep secret)
BACKEND_PRIVATE_KEY=

# MongoDB connection
MONGODB_URI=mongodb://localhost:27017/payguard

# Claude API (optional) - if missing, AI responses are mocked
CLAUDE_API_KEY=

# Reviewer address (authorized on-chain)
REVIEWER_ADDRESS=

# App URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000
